---
// Rep 1 placeholder. Real sequel.co pages land in spec 001.
const title = 'blueprint-sequel rep 1 — foundation green';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: #0a0a0a;
        color: #f5f5f5;
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          sans-serif;
      }
      main {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
      }
      h1 {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        font-weight: 600;
        text-align: center;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
    </main>
  </body>
</html>
